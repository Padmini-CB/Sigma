    "y_offset": 0,
    "filler_words": [
      "the",
      "a",
      "an",
      "for",
      "in",
      "of",
      "and",
      "to",
      "is",
      "with",
      "how",
      "what",
      "why",
      "your",
      "you",
      "this",
      "that"
    ],
    "highlight_trigger": "[]",
    "style_presets": {
      "bold_clean": {
        "label": "Bold Clean",
        "fill": true,
        "gradient": false,
        "stroke": false,
        "mixed_weight": false
      },
      "gradient_impact": {
        "label": "Gradient Impact",
        "fill": false,
        "gradient": true,
        "gradient_type": "linear",
        "gradient_direction": "left-right",
        "stroke": false,
        "mixed_weight": false
      },
      "outlined": {
        "label": "Outlined",
        "fill": false,
        "gradient": false,
        "stroke": true,
        "stroke_width": 8,
        "mixed_weight": false
      },
      "mixed_weight": {
        "label": "Mixed Weight",
        "fill": true,
        "gradient": false,
        "stroke": false,
        "mixed_weight": true
      }
    },
    "brand_colors": [
      {
        "label": "Lime",
        "hex": "#D7EF3F"
      },
      {
        "label": "White",
        "hex": "#FFFFFF"
      },
      {
        "label": "Teal",
        "hex": "#20C997"
      },
      {
        "label": "Blue",
        "hex": "#3B82F6"
      },
      {
        "label": "Purple",
        "hex": "#6F53C1"
      },
      {
        "label": "Orange",
        "hex": "#FD7E15"
      },
      {
        "label": "Pink",
        "hex": "#D63384"
      }
