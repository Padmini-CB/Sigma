{
  "brand": "Codebasics",
  "canvas": {
    "width": 1920,
    "height": 1080,
    "ratio": "16:9"
  },
  "colors": {
    "background_options": {
      "Blue": "#3B82F6",
      "Purple": "#6F53C1",
      "Blue-Gray": "#3F4C78",
      "Dark Navy": "#181830"
    },
    "glow_options": [
      "#20C997",
      "#E1E3FA",
      "#FD7E15",
      "#D63384"
    ],
    "highlight_color": "#D7EF3F",
    "text_white": "#FFFFFF"
  },
  "background_logic": {
    "modes": [
      "Radial Gradient"
    ],
    "gradient_darkening_factor": 0.4
  },
  "element_layer": {
    "max_elements": 3,
    "default_opacity": 20,
    "default_blur": 2,
