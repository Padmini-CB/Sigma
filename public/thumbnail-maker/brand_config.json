      "top-left": {
        "x": 12,
        "y": 12
      },
      "top-right": {
        "x": 80,
        "y": 12
      },
      "bottom-left": {
        "x": 12,
        "y": 80
      },
      "bottom-right": {
        "x": 80,
        "y": 80
      },
      "center-left": {
        "x": 12,
        "y": 45
      },
      "center-right": {
        "x": 80,
        "y": 45
      }
    }
  },
  "character_logic": {
    "glow_style": "edge_rim",
    "glow_color": "#20C997",
    "glow_intensity": 4,
    "glow_opacity": 0.2,
    "shadow_blur": 20,
    "shadow_opacity": 0.25,
    "zone_percent": 40,
    "x_offset": 0,
    "y_offset": 0
